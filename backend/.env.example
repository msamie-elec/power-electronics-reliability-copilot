########################################
# Application
########################################

APP_NAME=Power Electronics Reliability Copilot API
APP_VERSION=0.6.0-dev
APP_ENV=development
FRONTEND_ORIGIN=http://localhost:5173

########################################
# Providers
########################################

AI_PROVIDER=openai
DOCUMENT_STORAGE_PROVIDER=local
SECRET_PROVIDER=local

########################################
# Local Storage Paths
########################################

UPLOAD_DIR=uploads
DOCUMENTS_DIR=documents
METADATA_DIR=metadata
CHUNKS_DIR=chunks
EMBEDDINGS_DIR=embeddings

########################################
# OpenAI
########################################

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EXTRACTION_MODEL=gpt-4.1-mini

########################################
# Azure OpenAI
########################################

AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-02-15-preview
AZURE_OPENAI_CHAT_DEPLOYMENT=
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=

########################################
# Neo4j
########################################

NEO4J_URI=
NEO4J_USERNAME=
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j

########################################
# Azure Blob Storage
########################################

AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_ACCOUNT_NAME=
AZURE_BLOB_CONTAINER_NAME=engineering-documents

########################################
# Azure Key Vault
########################################

AZURE_KEY_VAULT_NAME=
AZURE_KEY_VAULT_URI=
AZURE_RESOURCE_GROUP=rg-powerelec-copilot-dev
AZURE_LOCATION=uksouth

########################################
# Azure Monitor / Application Insights
# Planned for v0.6.0 / v0.7.0
########################################

AZURE_APPLICATIONINSIGHTS_CONNECTION_STRING=
AZURE_APPLICATIONINSIGHTS_ENABLED=false

########################################
# Azure AI Search
# Planned for v0.7.0
########################################

AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_API_KEY=
AZURE_SEARCH_INDEX_NAME=engineering-documents-index

########################################
# Deployment
# Planned for v0.7.0
########################################

AZURE_CONTAINER_APP_NAME=power-electronics-copilot-api
AZURE_CONTAINER_APP_ENVIRONMENT=power-electronics-copilot-env
AZURE_CONTAINER_REGISTRY=
AZURE_STATIC_WEB_APP_NAME=power-electronics-copilot-web

########################################
# Observability
########################################

ENABLE_TELEMETRY=false
LOG_LEVEL=INFO
APPLICATIONINSIGHTS_CONNECTION_STRING=

########################################
# Health Diagnostics
########################################

ENABLE_HEALTH_DIAGNOSTICS=true